# ============ REQUIRED ============
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ============ OPTIONAL ============
PORT=4000

# Cloudinary (required for image uploads)
# Aliases: CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_SECRET also supported
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_api_secret

# CORS: comma-separated allowed origins (defaults to localhost:5173,5174 if unset)
# On Vercel, elite-admin-one.vercel.app is always allowed. Add your frontend URL here:
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Frontend URL (for emails/links)
# FRONTEND_URL=http://localhost:5173

# Email (Nodemailer)
# Aliases: MAIL_HOST, MAIL_USER, MAIL_PASS also supported
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM="Your Store" <your-email@gmail.com>

# Vonage SMS
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_FROM=Elite

# Vercel serverless
# VERCEL=1
